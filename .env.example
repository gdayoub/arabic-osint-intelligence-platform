APP_NAME=Arabic OSINT Platform
ENVIRONMENT=development
LOG_LEVEL=INFO

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=arabic_osint
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Optional override for non-Postgres local runs (example: sqlite:///data/osint.db)
# DATABASE_URL=

REQUEST_TIMEOUT_SECONDS=15
SCRAPE_DELAY_SECONDS=0.8
MAX_ARTICLES_PER_SOURCE=120
MAX_PAGES_PER_SOURCE=6
SCRAPE_SECTIONS_ENABLED=true
SCRAPE_ARCHIVES_ENABLED=true
MIN_ARTICLE_BODY_CHARS=120
REMOVE_STOPWORDS_DEFAULT=true

TOPIC_KEYWORDS_PATH=src/config/topic_keywords.json

ALJAZEERA_SEED_URLS=https://www.aljazeera.net/news,https://www.aljazeera.net/politics,https://www.aljazeera.net/economy
BBC_ARABIC_SEED_URLS=https://www.bbc.com/arabic,https://www.bbc.com/arabic/middleeast,https://www.bbc.com/arabic/business,https://www.bbc.com/arabic/world
CNN_ARABIC_SEED_URLS=https://arabic.cnn.com/middle-east,https://arabic.cnn.com/world,https://arabic.cnn.com/business
